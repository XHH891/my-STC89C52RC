 275          void one_sendbyte(unsigned char Byte)//写整个字节
 276          {
 277   1          unsigned char i;
 278   1        
 279   1          for(i=0;i<8;i++)
 280   1          {
 281   2              one_sendbit(Byte&(0x01<<i));
 282   2          } 
 283   1      }
 284          
 285          unsigned char one_receivebyte(void)//读整个字节
 286          {
 287   1          unsigned char i,Byte=0x00;
 288   1          for(i=0;i<8;i++)
 289   1          {
 290   2              if(one_receivebit())
 291   2              {
 292   3                Byte |= (0x01<<i);
 293   3              }
 294   2          }
 295   1          return Byte;
 296   1      }
