 321   2        }
 322   1      }
 323          unsigned char i2c_receivebyte(void)//接收一个字节
 324          {
 325   1        unsigned char i,byte=0x00;
 326   1        
 327   1        I2C_SDA = 1;
 328   1        for(i=0;i<8;i++)
