 205          float ds18b20_readt(void)//读取温度
 206          {
 207   1          unsigned char tlsb,tmlb;
 208   1          int temp;
 209   1          float t;
 210   1          onewire_init();//单总线初始化：建立通信的前提
 211   1          one_sendbyte(DS18B20_CMD_SKIP_ROM);
 212   1          one_sendbyte(DS18B20_CMD_READ_SCRATCHPAD);//告诉传感器 “要读温度数据了”
 213   1          tlsb = one_receivebyte();// 先读低8位（暂存器第0字节）
 214   1          tmlb = one_receivebyte();// 后读高8位（暂存器第1字节）
 215   1          temp = (tmlb<<8)|tlsb;//把两个 8 位字节合成完整的温度数据
 216   1          t = temp/16.0;//把原始数据转换成可读的浮点温度
 217   1          return t;
 218   1      }
