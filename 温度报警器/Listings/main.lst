 251   1          DQ = Bit;
 252   1          i = 22;while (--i); //delay 50us
 253   1          DQ = 1;
 254   1          EA = 1;
 255   1      }
 256          
 257          unsigned char one_receivebit(void)//读1或者0
 258          {
 259   1          unsigned char i,Bit;
 260   1          
 261   1          EA = 0;//防止被定时器按键扫描打断
 262   1          
 263   1          DQ = 0;
 264   1          i = 2;while (--i);  //delay 5us
 265   1          DQ = 1;
 266   1          i = 2;while (--i);  //delay 5us
 267   1          Bit = DQ;
 268   1          i = 22;while (--i); //delay 50us
 269   1        
 270   1          EA = 1;
 271   1        
 272   1          return Bit;
 273   1      }
