 313          void i2c_semdbyte(unsigned char byte)//写入一个字节
 314          {
 315   1        unsigned char i;
 316   1        for(i=0;i<8;i++)
 317   1        {
 318   2          I2C_SDA = (byte&(0x80>>i));
 319   2          I2C_SCL = 1;
